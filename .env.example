# Copy to .env.local and paste real values. .env.local is gitignored.
# See docs/AUTH_SETUP.md for the full local-dev walkthrough.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional — only used when Supabase keys are absent, to gate the local
# demo roster in src/lib/useAuthStore.js.
# VITE_AVALON_DEMO_PASSWORD=

# Server-only. Required for live checkout confirmation summary tokens.
# Use a random high-entropy value and set it in Vercel server envs only.
APPOINTMENT_SUMMARY_TOKEN_SECRET=
