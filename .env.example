# Copy to .env.local and paste real values. .env.local is gitignored.
# See docs/AUTH_SETUP.md for the full local-dev walkthrough.

PUBLIC_SITE_URL=https://snooches.avalonvitality.co

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# Production/staging live API switch. The browser flag disables demo auth in
# the shipped bundle; server functions also accept either flag for live vendor
# actions. Keep both set to the same value in Vercel environments.
VITE_AVALON_ENABLE_LIVE_API=false
AVALON_ENABLE_LIVE_API=false

# Optional — only used when Supabase keys are absent, to gate the local
# demo roster in src/lib/useAuthStore.js.
VITE_AVALON_DEMO_AUTH=
VITE_AVALON_DEMO_PASSWORD=
VITE_AVALON_ENABLE_FIRST_PARTY_ANALYTICS=false
VITE_APP_VERSION=
VITE_SENTRY_DSN=
VITE_ADMIN_PREVIEW=

# Auth provider exposure. Keep false until the matching Supabase Auth provider
# is configured and `npm run test:oauth-config` passes. Disabled providers stay
# hidden in the UI so snooches never exposes broken launch paths.
VITE_AUTH_GOOGLE_ENABLED=false
VITE_AUTH_APPLE_ENABLED=false
VITE_AUTH_PHONE_ENABLED=false
VITE_AUTH_PASSKEY_ENABLED=false

# Stripe Checkout / webhooks.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_EXPIRES_MINUTES=
STRIPE_WEBHOOK_MAX_BODY_BYTES=
STRIPE_WEBHOOK_PROCESSING_TIMEOUT_MS=

# Server-only Supabase service role for API writes.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Legacy fallback only; prefer SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=

# Server-only. Required for live checkout confirmation summary tokens.
# Use a random high-entropy value and set it in Vercel server envs only.
APPOINTMENT_SUMMARY_TOKEN_SECRET=

# Server-only live integrations.
AVALON_INTERNAL_API_SECRET=
ACUITY_USER_ID=
ACUITY_API_KEY=
ACUITY_DEFAULT_TYPE_ID=
ACUITY_TYPE_IV_VITAMINS=
ACUITY_TYPE_IV_NAD=
ACUITY_TYPE_IV_CBD=
ACUITY_TYPE_IM_SHOTS=
ACUITY_TYPE_MEMBERSHIP=
ACUITY_TYPE_HYDRATION=
ACUITY_TYPE_ENERGY=
ACUITY_TYPE_IMMUNITY=
ACUITY_TYPE_BEAUTY=
ACUITY_TYPE_RECOVERY=
ACUITY_TYPE_JETLAG=
ACUITY_TYPE_MYERS=
ACUITY_TYPE_HANGOVER=
VITE_ACUITY_DEFAULT_TYPE_ID=
VITE_ACUITY_TYPE_HYDRATION=
VITE_ACUITY_TYPE_MYERS=
VITE_ACUITY_TYPE_ENERGY=
VITE_ACUITY_TYPE_IMMUNITY=
VITE_ACUITY_TYPE_BEAUTY=
VITE_ACUITY_TYPE_RECOVERY=
VITE_ACUITY_TYPE_HANGOVER=
VITE_ACUITY_TYPE_JETLAG=
VITE_ACUITY_TYPE_IV_NAD=
VITE_ACUITY_TYPE_IV_CBD=
VITE_ACUITY_TYPE_IM_SHOTS=
VITE_ACUITY_TYPE_MEMBERSHIP=
VITE_ACUITY_TYPE_EVENT=
VITE_ACUITY_TYPE_EVENT_PRESALE=
ACUITY_WEBHOOK_SECRET=
ACUITY_WEBHOOK_FETCH_TIMEOUT_MS=
ACUITY_WEBHOOK_MAX_BODY_BYTES=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
AVALON_OPERATIONS_EMAIL=
# Attio CRM — LEGACY. Kept while HubSpot rolls out; removed in a follow-up PR.
# api/_attio.js refuses outbound calls when ATTIO_SYNC_ENABLED is not "true".
ATTIO_SYNC_ENABLED=false
ATTIO_ACCESS_TOKEN=
ATTIO_API_KEY=
ATTIO_WORKSPACE_ID=
ATTIO_PEOPLE_OBJECT=
VITE_ATTIO_CONFIGURED=

# HubSpot CRM. Un-BAA'd — api/_hubspot.js ships CRM-safe (identifiers +
# hospitality profile) only, guarded by scripts/no-phi-in-hubspot-qa.mjs. Set
# HUBSPOT_SYNC_ENABLED=true after the private-app token + custom properties are
# provisioned in the HubSpot portal. See docs/PHI_DATA_FLOW.md.
HUBSPOT_SYNC_ENABLED=false
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
VITE_HUBSPOT_CONFIGURED=
BOOKING_DEPOSIT_DOLLARS=
EVENT_PRESALE_WEBHOOK_SECRET=

# Optional SMS provider / Supabase auth hook.
QUO_API_KEY=
QUO_FROM_NUMBER=
SEND_SMS_HOOK_SECRET=
SEND_SMS_ALLOWED_COUNTRY_PREFIXES=
SEND_SMS_MAX_BODY_BYTES=

# Server-only. Persistent rate-limit backend for public lookup/auth endpoints.
# Without these, functions fall back to per-instance memory buckets.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Verification-only. Use a mailbox you control; verifiers create plus-addresses.
API_BASE_URL=https://snooches.avalonvitality.co
STRIPE_TEST_SECRET_KEY=
ACUITY_VERIFY=
VERIFY_EMAIL_ROOT=
PASSWORD_RESET_REDIRECT_TO=https://snooches.avalonvitality.co/account/new-password

# Legacy/imported Base44 placeholders. Leave blank unless a legacy surface needs them.
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
