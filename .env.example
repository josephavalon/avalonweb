# Copy to .env.local and paste real values. .env.local is gitignored.
# See docs/AUTH_SETUP.md for the full local-dev walkthrough.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Production/staging live API switch. The browser flag disables demo auth in
# the shipped bundle; server functions also accept either flag for live vendor
# actions. Keep both set to the same value in Vercel environments.
VITE_AVALON_ENABLE_LIVE_API=false
AVALON_ENABLE_LIVE_API=false

# Optional — only used when Supabase keys are absent, to gate the local
# demo roster in src/lib/useAuthStore.js.
# VITE_AVALON_DEMO_PASSWORD=

# Stripe Checkout / webhooks.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server-only Supabase service role for API writes.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Required for live checkout confirmation summary tokens.
# Use a random high-entropy value and set it in Vercel server envs only.
APPOINTMENT_SUMMARY_TOKEN_SECRET=

# Server-only live integrations.
AVALON_INTERNAL_API_SECRET=
ACUITY_USER_ID=
ACUITY_API_KEY=
ACUITY_WEBHOOK_SECRET=
RESEND_API_KEY=
AVALON_OPERATIONS_EMAIL=
ATTIO_ACCESS_TOKEN=
ATTIO_WORKSPACE_ID=
ATTIO_PEOPLE_OBJECT=

# Server-only. Persistent rate-limit backend for public lookup/auth endpoints.
# Without these, functions fall back to per-instance memory buckets.
KV_REST_API_URL=
KV_REST_API_TOKEN=
