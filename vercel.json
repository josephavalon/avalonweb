{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/expire-credits", "schedule": "0 3 * * *" },
    { "path": "/api/cron/post-visit-survey", "schedule": "0 16 * * *" }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/b2b",
      "destination": "/b2b.html"
    },
    {
      "source": "/b2b/",
      "destination": "/b2b.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(account|account/.*|admin|admin/.*|apply|athlete|auth|auth/.*|book|booking|booking/.*|book-now|careers|checkout|checkout/.*|cookie-policy|cookies|corporate|custom|dashboard|events|events/.*|faq|forgot|forgot-password|gift|hangover|hipaa-notice|hotel|ingredients|invite|invite/.*|iv-therapy|jet-lag|kiosk|launches|launches/.*|learn|learn/.*|locations|locations/.*|login|medical-direction|membership|members|members/.*|menu|notice-of-privacy-practices|nurse|nurses|order|our-story|our-team|partners|platform|plan|plans|plan-checkout|plans/checkout|presale|presale/.*|press|pricing|privacy|privacy-policy|product-disclaimer|products/.*|protocols|provider|provider/.*|providers|provider/login|redeem|review|safety|service-area|services|services/.*|signin|sign-in|signup|store|store/.*|subscribe|subscription|team|telehealth-disclaimer|terms|terms-and-conditions|terms-of-service|therapies/.*|trips|trips/.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/bags/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD, OPTIONS" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "snooches.avalonvitality.co"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "beta.avalonvitality.co"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "care.avalonvitality.co"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(), interest-cohort=(), payment=(self \"https://checkout.stripe.com\" \"https://js.stripe.com\")"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'sha256-BBL6wzWMk0biPpDXn2mUa0e/Xi/+z26OVRepNJTTQ7c=' https://fonts.googleapis.com https://js.stripe.com https://translate.google.com https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://translate.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://api.resend.com https://api.stripe.com https://acuityscheduling.com https://translate.googleapis.com https://translate.google.com https://*.supabase.co wss://*.supabase.co https://vercel.live wss://vercel.live; frame-src https://js.stripe.com https://hooks.stripe.com https://checkout.stripe.com https://translate.google.com https://vercel.live; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com; object-src 'none'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!assets/|favicon|.*\\.(?:js|css|png|jpg|jpeg|webp|svg|ico|json|xml|txt|woff|woff2|mp4)).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ]
}
